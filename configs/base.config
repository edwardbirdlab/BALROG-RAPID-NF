/*
 * BALROG-RAPID Base Configuration
 *
 * Resource labels, error handling, and publishDir settings
 */

process {

    // Defaults
    cpus   = { check_max( 1    * task.attempt, 'cpus'   ) }
    memory = { check_max( 6.GB * task.attempt, 'memory' ) }
    time   = { check_max( 4.h  * task.attempt, 'time'   ) }

    // Retry on common transient failures (signals 130-145, I/O error 104)
    errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
    maxRetries    = 3
    maxErrors     = '-1'

    // --- Resource Labels ---

    withLabel: ultralow {
        cpus   = { check_max( 1                  , 'cpus'   ) }
        memory = { check_max( 5.GB * task.attempt, 'memory' ) }
        time   = { check_max( 2.h  * task.attempt, 'time'   ) }
    }

    withLabel: lowmem {
        cpus   = { check_max( 8                   , 'cpus'   ) }
        memory = { check_max( 16.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h   * task.attempt, 'time'   ) }
    }

    withLabel: kraken2 {
        cpus   = { check_max( 16                  , 'cpus'   ) }
        memory = { check_max( 456.GB * task.attempt, 'memory' ) }
        time   = { check_max( 24.h  * task.attempt, 'time'   ) }
    }

    withLabel: sylph_profile {
        cpus   = { check_max( 16                  , 'cpus'   ) }
        memory = { check_max( 150.GB * task.attempt, 'memory' ) }
        time   = { check_max( 1.h   * task.attempt, 'time'   ) }
    }

    withLabel: diamond {
        cpus   = { check_max( 8                   , 'cpus'   ) }
        memory = { check_max( 16.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h   * task.attempt, 'time'   ) }
    }

    withLabel: spades_subset {
        cpus   = { check_max( 16                  , 'cpus'   ) }
        memory = { check_max( 32.GB * task.attempt, 'memory' ) }
        time   = { check_max( 6.h   * task.attempt, 'time'   ) }
    }

    withLabel: amrfinder {
        cpus   = { check_max( 8                   , 'cpus'   ) }
        memory = { check_max( 16.GB * task.attempt, 'memory' ) }
        time   = { check_max( 2.h   * task.attempt, 'time'   ) }
    }
}


/*
 * PublishDir configuration
 *
 * Routes outputs to Phase 2 compatible directory structure:
 *   taxonomy/kraken2/  - Kraken2 reports (unified DB)
 *   taxonomy/sylph/    - Sylph profiles
 *   host/kraken2/      - Kraken2 reports (host DBs)
 *   amr/diamond/       - Diamond BLASTX results
 *   amr/extracted_reads/ - seqtk subset reads
 *   amr/assemblies/    - SPAdes micro-assembly contigs
 *   amr/amrfinder/     - AMRFinder results
 *   qc/                - QC reports and trimming results
 */

process {

    // Default publishDir (fallback for unlisted processes)
    publishDir = [
        path:    { "${params.outdir}/other" },
        mode:    params.publish_dir_mode == 'default' ? null : params.publish_dir_mode,
        enabled: false
    ]

    // --- QC outputs ---
    withName: 'FASTQC_RAW' {
        publishDir = [
            path: { "${params.outdir}/qc/fastqc_raw" },
            mode: params.publish_dir_mode == 'default' ? null : params.publish_dir_mode
        ]
    }
    withName: 'FASTP' {
        publishDir = [
            path: { "${params.outdir}/qc/fastp" },
            mode: params.publish_dir_mode == 'default' ? null : params.publish_dir_mode
        ]
    }
    withName: 'FASTQC_TRIMMED' {
        publishDir = [
            path: { "${params.outdir}/qc/fastqc_trimmed" },
            mode: params.publish_dir_mode == 'default' ? null : params.publish_dir_mode
        ]
    }

    // --- Taxonomy outputs (Phase 2 compatible) ---
    withName: 'KRAKEN2' {
        publishDir = [
            path: { "${params.outdir}/taxonomy/kraken2" },
            mode: params.publish_dir_mode == 'default' ? null : params.publish_dir_mode
        ]
    }
    withName: 'SYLPH' {
        publishDir = [
            path: { "${params.outdir}/taxonomy/sylph" },
            mode: params.publish_dir_mode == 'default' ? null : params.publish_dir_mode
        ]
    }

    // --- Host profiling outputs ---
    withName: 'KRAKEN2_HOST' {
        publishDir = [
            path: { "${params.outdir}/host/kraken2" },
            mode: params.publish_dir_mode == 'default' ? null : params.publish_dir_mode
        ]
    }

    // --- AMR outputs (Phase 2 compatible) ---
    withName: 'DIAMOND_BLASTX' {
        publishDir = [
            path: { "${params.outdir}/amr/diamond" },
            mode: params.publish_dir_mode == 'default' ? null : params.publish_dir_mode
        ]
    }
    withName: 'SEQTK_SUBSEQ' {
        publishDir = [
            path: { "${params.outdir}/amr/extracted_reads" },
            mode: params.publish_dir_mode == 'default' ? null : params.publish_dir_mode
        ]
    }
    withName: 'SPADES' {
        publishDir = [
            path: { "${params.outdir}/amr/assemblies" },
            mode: params.publish_dir_mode == 'default' ? null : params.publish_dir_mode
        ]
    }
    withName: 'AMRFINDER' {
        publishDir = [
            path: { "${params.outdir}/amr/amrfinder" },
            mode: params.publish_dir_mode == 'default' ? null : params.publish_dir_mode
        ]
    }

    // --- Pipeline info ---
    withName: 'COLLECT_VERSIONS' {
        publishDir = [
            path: { "${params.outdir}/pipeline_info" },
            mode: params.publish_dir_mode == 'default' ? null : params.publish_dir_mode
        ]
    }
}
