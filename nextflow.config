/*
 * BALROG-RAPID Nextflow Pipeline Configuration
 *
 * Metagenomic pathogen detection, host profiling, and AMR detection
 */

nextflow.enable.dsl = 2

// Max resource limits (overwrite in profile or CLI)
params.max_memory = '750.GB'
params.max_cpus   = 36
params.max_time   = '24.h'

// --- Input ---
params.sample_sheet = null       // CSV: sample,r1,r2
params.outdir       = './results'
params.project_name = 'BALROG'
params.publish_dir_mode = 'default' // Options: 'default', 'copy', 'symlink', 'link'

// --- Databases ---
params.kraken2_db  = null    // Path to unified Kraken2 database
params.sylph_db    = null    // Path to Sylph database (.syldb)
params.diamond_db  = null    // Path to Diamond AMR database (.dmnd)
params.host_sheet  = null    // Optional CSV: host_name,kraken2_db

// --- Kraken2 Parameters ---
params.k2_confidence     = 0.3
params.k2_min_hit_groups = 3

// --- FASTP Trimming Parameters ---
params.fastp_q      = 20    // Minimum quality score
params.fastp_minlen = 100   // Minimum read length after trimming

// --- Diamond Parameters ---
params.diamond_evalue      = '1e-10'
params.diamond_max_targets = 500

// --- SPAdes Parameters ---
params.spades_memory = 16   // GB, for micro-assembly of AMR reads

// --- Optional Steps ---
params.run_qc             = true   // Run FASTP + FastQC
params.run_taxonomy       = true   // Run Kraken2 + Sylph
params.run_host_profiling = true   // Run Kraken2 against host genome(s)
params.run_amr            = true   // Run AMR subset detection pipeline
params.run_multiqc        = true   // Run MultiQC aggregation report

// --- MultiQC ---
params.multiqc_config = "${projectDir}/configs/multiqc_config.yaml"


// Load base config for resource labels and error handling
includeConfig 'configs/base.config'


// Function to ensure resource requests don't exceed maximum limits
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max memory '${params.max_memory}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max time '${params.max_time}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "   ### ERROR ###   Max cpus '${params.max_cpus}' is not valid! Using default value: $obj"
            return obj
        }
    }
}
